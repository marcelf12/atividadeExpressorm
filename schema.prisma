datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id      Int     @id @default(autoincrement())
  nome    String
  email   String  @unique
  perfil  Perfil?
}

model Perfil {
  id         Int     @id @default(autoincrement())
  nome       String
  usuarioId  Int     @unique
  usuario    Usuario @relation(fields: [usuarioId], references: [id])
}